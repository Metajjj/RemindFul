<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/home2Bg"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#AB9866">

    <FrameLayout
        android:id="@+id/home2FragHolder"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:onClick="Temp"
        android:id="@+id/home2Title"
        android:layout_width="0dp"
        android:layout_height="98dp"
        android:layout_marginStart="50dp"
        android:layout_marginLeft="50dp"
        android:layout_marginTop="50dp"
        android:layout_marginEnd="50dp"
        android:layout_marginRight="50dp"
        android:text="RemindFul"
        android:textColor="#f4d882"
        android:textSize="48sp"
        android:textStyle="bold"
        app:autoSizeTextType="uniform"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:onClick="Switchy"
        android:id="@+id/home2ViewStyle"
        android:layout_width="104dp"
        android:layout_height="82dp"
        android:layout_marginStart="40dp"
        android:layout_marginLeft="40dp"
        android:layout_marginTop="4dp"
        android:shadowColor="#d4d8a2"
        android:shadowDx="-3"
        android:shadowDy="5"
        android:shadowRadius="10"
        android:text="Recent"
        android:textColor="#db863e"
        android:textStyle="bold"
        app:autoSizeTextType="uniform"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/home2Title" />

    <ScrollView
        android:id="@+id/NewNoteScroll"
        android:layout_width="355dp"
        android:layout_height="430dp"
        android:layout_marginStart="25dp"
        android:layout_marginLeft="25dp"
        android:layout_marginTop="20dp"
        android:layout_marginBottom="50dp"
        android:contentDescription="Grid style list of notes"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/home2ViewStyle">

        <TableLayout
            android:id="@+id/NewNoteTable"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:stretchColumns="*">
        </TableLayout>

    </ScrollView>

    <ImageView
        android:onClick="Menu"
        android:contentDescription="Menu"
        android:id="@+id/imageView"
        android:layout_width="50dp"
        android:layout_height="75dp"
        android:layout_marginTop="5dp"
        android:layout_marginEnd="60dp"
        android:layout_marginRight="60dp"
        android:layout_marginBottom="20dp"
        android:background="@drawable/roundbordernote"
        app:layout_constraintBottom_toTopOf="@+id/NewNoteScroll"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/home2Title"
        app:srcCompat="@drawable/cm" />

</androidx.constraintlayout.widget.ConstraintLayout>