<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/home2Bg"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#AB9866">

    <TextView
        android:onClick="TempLoad"
        android:id="@+id/home2Title"
        android:layout_width="0dp"
        android:layout_height="98dp"
        android:layout_marginStart="50dp"
        android:layout_marginLeft="50dp"
        android:layout_marginTop="50dp"
        android:layout_marginEnd="50dp"
        android:layout_marginRight="50dp"
        android:text="RemindFul"
        android:textColor="#f4d882"
        android:textSize="48sp"
        android:textStyle="bold"
        app:autoSizeTextType="uniform"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:tag="ThisIsMyID"

        android:onClick="Switchy"
        android:id="@+id/home2ViewStyle"
        android:layout_width="104dp"
        android:layout_height="82dp"
        android:layout_marginStart="40dp"
        android:layout_marginLeft="40dp"
        android:layout_marginTop="4dp"
        android:shadowColor="#d4d8a2"
        android:shadowDx="-3"
        android:shadowDy="5"
        android:shadowRadius="10"
        android:text="Recent"
        android:textColor="#db863e"
        android:textStyle="bold"
        app:autoSizeTextType="uniform"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/home2Title" />

